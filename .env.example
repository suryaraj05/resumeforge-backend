# Option A — paste the entire JSON service account on ONE line (easiest on Railway/Vercel)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Option B — three separate variables (local .env)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Must match the bucket in Firebase Console (e.g. podnotes-eed71.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=
# Gemini: one key OR many (round-robin per AI call spreads quota). Prefer GEMINI_API_KEYS for 10 keys:
# GEMINI_API_KEYS=key1,key2,key3,key4,key5,key6,key7,key8,key9,key10
# Alternative: GEMINI_API_KEY_1=... through GEMINI_API_KEY_10=... (only used if GEMINI_API_KEYS is empty)
GEMINI_API_KEY=your-gemini-api-key
# Optional: force a model. If unset or invalid, the API picks the first working id at startup (see src/lib/geminiModels.ts).
# Run: npm run gemini:probe
GEMINI_MODEL=
PORT=4000
# Comma-separated allowed browser origins (Vercel prod + preview URLs)
ALLOWED_ORIGIN=http://localhost:3000
# Public web origin for share links (e.g. https://yourapp.vercel.app)
APP_PUBLIC_URL=http://localhost:3000

# Phase 7 — job discovery & salary (optional)
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
APIFY_API_TOKEN=
SERPAPI_KEY=

# Docker / Railway: set automatically in Dockerfile. Local Mac/Windows: leave unset (Puppeteer bundled Chromium).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
