# Option A — paste the entire JSON service account on ONE line (easiest on Railway/Vercel)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Option B — three separate variables (local .env)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Must match the bucket in Firebase Console (e.g. podnotes-eed71.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=podnotes-eed71.firebasestorage.app
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
PORT=4000
# Comma-separated allowed browser origins (Vercel prod + preview URLs)
ALLOWED_ORIGIN=http://localhost:3000
# Public web origin for share links (e.g. https://yourapp.vercel.app)
APP_PUBLIC_URL=http://localhost:3000
